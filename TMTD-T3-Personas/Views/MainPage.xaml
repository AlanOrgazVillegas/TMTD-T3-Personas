<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TMTD_T3_Personas.MainPage"
             Title="Directorio de Personas">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <!-- FORMULARIO -->
            <Label Text="FORMULARIO" FontAttributes="Bold"/>

            <Entry Placeholder="Nombre"
                   Text="{Binding PersonaActual.Nombre}"/>
            <Entry Placeholder="Apellido"
                   Text="{Binding PersonaActual.Apellido}"/>
            <Entry Placeholder="Email"
                   Text="{Binding PersonaActual.Email}"
                   Keyboard="Email"/>
            <Entry Placeholder="Teléfono"
                   Text="{Binding PersonaActual.Telefono}"
                   Keyboard="Telephone"/>

            <!-- BOTONES CRUD -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="5">
                <Button Grid.Column="0" Text="Guardar"
                        Command="{Binding GuardarCommand}"/>
                <Button Grid.Column="1" Text="Eliminar"
                        Command="{Binding EliminarCommand}"/>
                <Button Grid.Column="2" Text="Limpiar"
                        Command="{Binding LimpiarCommand}"/>
                <Button Grid.Column="3" Text="Sincronizar"
                        Command="{Binding SincronizarCommand}"/>
            </Grid>

            <!-- ESTADO -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"/>
            <Label Text="{Binding Mensaje}"/>

            <!-- SEPARADOR -->
            <BoxView HeightRequest="1" Color="LightGray"/>
            <Label Text="LISTA DE PERSONAS" FontAttributes="Bold"/>

            <!-- LISTA -->
            <CollectionView ItemsSource="{Binding Personas}"
                            SelectionMode="Single"
                            SelectedItem="{Binding PersonaActual}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="0,8" Spacing="2">
                            <Label FontAttributes="Bold">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Path="Nombre"/>
                                        <Binding Path="Apellido"/>
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Label Text="{Binding Email}" FontSize="13"/>
                            <Label Text="{Binding Telefono}" FontSize="13"/>
                            <BoxView HeightRequest="1" Color="LightGray" Margin="0,6"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Mostrar ruta de la BD -->
            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10"/>
            <Label Text="Base de Datos Local:" FontAttributes="Bold" FontSize="12"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                <Label Grid.Column="0" Text="{Binding RutaBD}" FontSize="10" 
           LineBreakMode="WordWrap" TextColor="Gray"/>
                <Button Grid.Column="1" Text="📋" Command="{Binding CopiarRutaCommand}" 
            WidthRequest="40" HeightRequest="30" FontSize="12"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>